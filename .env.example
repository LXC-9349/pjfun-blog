# ===========================================
# Site Configuration (站点配置)
# ===========================================

# Site basic information
VITE_SITE_ICON=Pj
VITE_SITE_TITLE=Pjfun Blog
VITE_SITE_DESCRIPTION=零后端、纯静态、顶级动效、全球秒开的个人博客系统
VITE_SITE_AUTHOR=Simon
VITE_SITE_KEYWORDS=博客,技术分享,前端开发,Vue,TypeScript
VITE_SITE_EMAIL=pjfun@aliyun.com

# Social links
VITE_SOCIAL_GITHUB=https://github.com/LXC-9349/pjfun-blog
VITE_SOCIAL_TELEGRAM=https://t.me/pjfun_top

# Footer links
VITE_FOOT_GITHUB=https://github.com/LXC-9349/pjfun-blog

# ===========================================
# Giscus Comment System (Giscus 评论系统)
# ===========================================
# Get your config from: https://giscus.app/zh-CN

# Enable comment system (true/false)
VITE_GISCUS_ENABLED=true

# GitHub repository (owner/repo)
VITE_GISCUS_REPO=LXC-9349/blog-comment

# Repository ID
VITE_GISCUS_REPO_ID=R_kgDOQmj5WA

# Discussion category
VITE_GISCUS_CATEGORY=Announcements

# Category ID
VITE_GISCUS_CATEGORY_ID=DIC_kwDOQmj5WM4CzpLf

# Mapping method (pathname, url, title, og:title, specific)
VITE_GISCUS_MAPPING=pathname

# Strict matching (true/false)
VITE_GISCUS_STRICT=false

# Enable reactions (true/false)
VITE_GISCUS_REACTIONS=true

# Emit metadata (true/false)
VITE_GISCUS_METADATA=false

# Input position (top, bottom)
VITE_GISCUS_POSITION=top

# Language (zh-CN, en, etc.)
VITE_GISCUS_LANG=zh-CN

# ===========================================
# Hot Tags (热门标签)
# ===========================================
# Comma-separated tags
VITE_HOT_TAGS=Vue,网页,文本,在线课程,编程教程,职业技能,知识管理,思维导图,学习笔记,教育心得,自我提升

# ===========================================
# Password Protection (密码保护)
# ===========================================
# 
# IMPORTANT: VITE_BLOG_PASSWORD has higher priority than VITE_BLOG_PASSWORD_HASH
# If both are set, only VITE_BLOG_PASSWORD will be used
#
# Option 1 (Recommended): Set plain text password
# The SHA256 hash will be automatically generated during build
VITE_BLOG_PASSWORD=

# Option 2: Set pre-generated SHA256 hash directly
# Only use this if VITE_BLOG_PASSWORD is not set
VITE_BLOG_PASSWORD_HASH=

# ===========================================
# Encryption Settings (加密设置)
# ===========================================
# Encryption settings for pjt.tool files
VITE_ENCRYPT_KEY=
VITE_ENCRYPT_IV=